module Test.Url exposing (main, tests)

import Basics exposing (..)
import Dict
import List
import Maybe exposing (..)
import String
import Url exposing (..)
import Url.Builder as Builder
import Url.Parser as Parser exposing ((</>), (<?>))
import Url.Parser.Query as Query
import Test exposing (..)
import Expect


main : Test
main =
    tests


parseUrl : Parser.Parser (a -> a) a -> String -> Maybe a
parseUrl parser urlString =
    case Url.fromString urlString of
        Just url ->
            Parser.parse parser url

        Nothing ->
            Nothing


tests : Test
tests =
    describe "Url Tests"
        [ percentTests
        , fromStringTests
        , fromStringEdgeCaseTests
        , toStringTests
        , builderTests
        , parserTests
        , parserAdditionalTests
        , queryParserTests
        , queryParserAdditionalTests
        , builderCustomTests
        ]



-- PERCENT ENCODING


percentTests : Test
percentTests =
    describe "Percent Encoding"
        [ test "encode simple string" <|
            \() -> Expect.equal "hello" (percentEncode "hello")
        , test "encode spaces" <|
            \() -> Expect.equal "hello%20world" (percentEncode "hello world")
        , test "encode special chars" <|
            \() -> Expect.equal "a%26b%3Dc" (percentEncode "a&b=c")
        , test "encode unicode" <|
            \() -> Expect.equal "%C3%A9" (percentEncode "\u{00E9}")
        , test "decode simple" <|
            \() -> Expect.equal (Just "hello") (percentDecode "hello")
        , test "decode percent" <|
            \() -> Expect.equal (Just "hello world") (percentDecode "hello%20world")
        , test "decode special chars" <|
            \() -> Expect.equal (Just "a&b=c") (percentDecode "a%26b%3Dc")
        , test "decode invalid returns Nothing" <|
            \() -> Expect.equal Nothing (percentDecode "%")
        , test "decode invalid hex returns Nothing" <|
            \() -> Expect.equal Nothing (percentDecode "%ZZ")
        , test "round-trip encode/decode" <|
            \() ->
                let
                    original = "hello world & friends=true"
                in
                Expect.equal (Just original) (percentDecode (percentEncode original))
        ]



-- FROM STRING


fromStringTests : Test
fromStringTests =
    describe "Url.fromString"
        [ test "simple http URL" <|
            \() ->
                case fromString "http://example.com/path" of
                    Just url ->
                        Expect.all
                            [ \u -> Expect.equal Http u.protocol
                            , \u -> Expect.equal "example.com" u.host
                            , \u -> Expect.equal Nothing u.port_
                            , \u -> Expect.equal "/path" u.path
                            , \u -> Expect.equal Nothing u.query
                            , \u -> Expect.equal Nothing u.fragment
                            ]
                            url
                    Nothing ->
                        Expect.fail "Expected Just, got Nothing"
        , test "https URL" <|
            \() ->
                case fromString "https://example.com" of
                    Just url ->
                        Expect.equal Https url.protocol
                    Nothing ->
                        Expect.fail "Expected Just"
        , test "URL with port" <|
            \() ->
                case fromString "http://localhost:8080/api" of
                    Just url ->
                        Expect.equal (Just 8080) url.port_
                    Nothing ->
                        Expect.fail "Expected Just"
        , test "URL with query" <|
            \() ->
                case fromString "http://example.com/search?q=test&lang=en" of
                    Just url ->
                        Expect.equal (Just "q=test&lang=en") url.query
                    Nothing ->
                        Expect.fail "Expected Just"
        , test "URL with fragment" <|
            \() ->
                case fromString "http://example.com/page#section" of
                    Just url ->
                        Expect.equal (Just "section") url.fragment
                    Nothing ->
                        Expect.fail "Expected Just"
        , test "URL with everything" <|
            \() ->
                case fromString "https://example.com:443/path?key=val#frag" of
                    Just url ->
                        Expect.all
                            [ \u -> Expect.equal Https u.protocol
                            , \u -> Expect.equal "example.com" u.host
                            , \u -> Expect.equal (Just 443) u.port_
                            , \u -> Expect.equal "/path" u.path
                            , \u -> Expect.equal (Just "key=val") u.query
                            , \u -> Expect.equal (Just "frag") u.fragment
                            ]
                            url
                    Nothing ->
                        Expect.fail "Expected Just"
        , test "invalid URL returns Nothing" <|
            \() -> Expect.equal Nothing (fromString "not-a-url")
        , test "ftp URL returns Nothing" <|
            \() -> Expect.equal Nothing (fromString "ftp://example.com")
        , test "root path" <|
            \() ->
                case fromString "http://example.com/" of
                    Just url ->
                        Expect.equal "/" url.path
                    Nothing ->
                        Expect.fail "Expected Just"
        ]



-- FROM STRING EDGE CASES


fromStringEdgeCaseTests : Test
fromStringEdgeCaseTests =
    describe "Url.fromString edge cases"
        [ test "empty string after protocol returns Nothing" <|
            \() -> Expect.equal Nothing (fromString "http://")
        , test "userinfo with @ returns Nothing" <|
            \() -> Expect.equal Nothing (fromString "http://user@example.com/path")
        , test "multiple colons in host returns Nothing" <|
            \() -> Expect.equal Nothing (fromString "http://host:80:90/path")
        , test "non-numeric port returns Nothing" <|
            \() -> Expect.equal Nothing (fromString "http://example.com:abc/path")
        , test "empty host with hash only returns Nothing" <|
            \() -> Expect.equal Nothing (fromString "http://#cats")
        , test "empty host with query only returns Nothing" <|
            \() -> Expect.equal Nothing (fromString "http://?q=1")
        , test "URL with empty fragment" <|
            \() ->
                case fromString "http://example.com/path#" of
                    Just url ->
                        Expect.equal (Just "") url.fragment
                    Nothing ->
                        Expect.fail "Expected Just"
        , test "URL with empty query" <|
            \() ->
                case fromString "http://example.com/path?" of
                    Just url ->
                        Expect.equal (Just "") url.query
                    Nothing ->
                        Expect.fail "Expected Just"
        , test "URL with fragment before query is parsed correctly" <|
            \() ->
                case fromString "http://example.com/path?q=1#frag" of
                    Just url ->
                        Expect.all
                            [ \u -> Expect.equal (Just "q=1") u.query
                            , \u -> Expect.equal (Just "frag") u.fragment
                            ]
                            url
                    Nothing ->
                        Expect.fail "Expected Just"
        , test "URL with no path but fragment" <|
            \() ->
                case fromString "http://example.com#top" of
                    Just url ->
                        Expect.all
                            [ \u -> Expect.equal "/" u.path
                            , \u -> Expect.equal (Just "top") u.fragment
                            ]
                            url
                    Nothing ->
                        Expect.fail "Expected Just"
        , test "URL with no path but query" <|
            \() ->
                case fromString "http://example.com?q=test" of
                    Just url ->
                        Expect.all
                            [ \u -> Expect.equal "/" u.path
                            , \u -> Expect.equal (Just "q=test") u.query
                            ]
                            url
                    Nothing ->
                        Expect.fail "Expected Just"
        , test "URL with deeply nested path" <|
            \() ->
                case fromString "http://example.com/a/b/c/d" of
                    Just url ->
                        Expect.equal "/a/b/c/d" url.path
                    Nothing ->
                        Expect.fail "Expected Just"
        ]



-- TO STRING


toStringTests : Test
toStringTests =
    describe "Url.toString"
        [ test "round-trip simple URL" <|
            \() ->
                case fromString "http://example.com/path" of
                    Just url ->
                        Expect.equal "http://example.com/path" (Url.toString url)
                    Nothing ->
                        Expect.fail "Expected Just"
        , test "round-trip URL with all parts" <|
            \() ->
                case fromString "https://example.com:8080/path?q=1#top" of
                    Just url ->
                        Expect.equal "https://example.com:8080/path?q=1#top" (Url.toString url)
                    Nothing ->
                        Expect.fail "Expected Just"
        ]



-- URL BUILDER


builderTests : Test
builderTests =
    describe "Url.Builder"
        [ describe "absolute"
            [ test "simple path" <|
                \() -> Expect.equal "/api/users" (Builder.absolute ["api", "users"] [])
            , test "path with query" <|
                \() ->
                    Expect.equal "/search?q=canopy"
                        (Builder.absolute ["search"] [Builder.string "q" "canopy"])
            , test "empty path" <|
                \() -> Expect.equal "/" (Builder.absolute [] [])
            , test "multiple query params" <|
                \() ->
                    Expect.equal "/items?page=1&limit=10"
                        (Builder.absolute ["items"]
                            [ Builder.int "page" 1
                            , Builder.int "limit" 10
                            ]
                        )
            ]
        , describe "relative"
            [ test "simple relative path" <|
                \() -> Expect.equal "api/users" (Builder.relative ["api", "users"] [])
            , test "relative with query" <|
                \() ->
                    Expect.equal "search?q=test"
                        (Builder.relative ["search"] [Builder.string "q" "test"])
            ]
        , describe "crossOrigin"
            [ test "cross-origin URL" <|
                \() ->
                    Expect.equal "https://api.example.com/v1/data"
                        (Builder.crossOrigin "https://api.example.com" ["v1", "data"] [])
            , test "cross-origin with query" <|
                \() ->
                    Expect.equal "https://api.example.com/search?q=test"
                        (Builder.crossOrigin "https://api.example.com" ["search"]
                            [Builder.string "q" "test"]
                        )
            ]
        , describe "toQuery"
            [ test "empty query" <|
                \() -> Expect.equal "" (Builder.toQuery [])
            , test "single param" <|
                \() -> Expect.equal "?a=1" (Builder.toQuery [Builder.string "a" "1"])
            , test "multiple params" <|
                \() ->
                    Expect.equal "?a=1&b=2"
                        (Builder.toQuery
                            [ Builder.string "a" "1"
                            , Builder.string "b" "2"
                            ]
                        )
            ]
        ]



-- URL PARSER


parserTests : Test
parserTests =
    describe "Url.Parser"
        [ describe "s and int"
            [ test "parse s \"blog\" </> int extracts blog post ID" <|
                \() ->
                    Expect.equal (Just 42)
                        (parseUrl (Parser.s "blog" </> Parser.int) "https://example.com/blog/42")
            , test "parse s \"blog\" </> int with trailing slash" <|
                \() ->
                    Expect.equal (Just 42)
                        (parseUrl (Parser.s "blog" </> Parser.int) "https://example.com/blog/42/")
            , test "parse s \"blog\" </> int fails on non-integer" <|
                \() ->
                    Expect.equal Nothing
                        (parseUrl (Parser.s "blog" </> Parser.int) "https://example.com/blog/wolf")
            , test "parse s \"blog\" </> int fails on missing segment" <|
                \() ->
                    Expect.equal Nothing
                        (parseUrl (Parser.s "blog" </> Parser.int) "https://example.com/blog/")
            ]
        , describe "s and string"
            [ test "parse s \"user\" </> string extracts username" <|
                \() ->
                    Expect.equal (Just "alice")
                        (parseUrl (Parser.s "user" </> Parser.string) "https://example.com/user/alice")
            , test "parse s \"user\" </> string with trailing slash" <|
                \() ->
                    Expect.equal (Just "bob")
                        (parseUrl (Parser.s "user" </> Parser.string) "https://example.com/user/bob/")
            ]
        , describe "top"
            [ test "top matches root path" <|
                \() ->
                    Expect.equal (Just ())
                        (parseUrl (Parser.map () Parser.top) "https://example.com/")
            , test "top matches root without trailing slash" <|
                \() ->
                    Expect.equal (Just ())
                        (parseUrl (Parser.map () Parser.top) "https://example.com")
            , test "top does not match non-root" <|
                \() ->
                    Expect.equal Nothing
                        (parseUrl (Parser.map () Parser.top) "https://example.com/blog")
            ]
        , describe "oneOf"
            [ test "oneOf matches first parser" <|
                \() ->
                    Expect.equal (Just "topic:cats")
                        (parseUrl
                            (Parser.oneOf
                                [ Parser.map (\t -> "topic:" ++ t) (Parser.s "topic" </> Parser.string)
                                , Parser.map (\i -> "blog:" ++ String.fromInt i) (Parser.s "blog" </> Parser.int)
                                ]
                            )
                            "https://example.com/topic/cats"
                        )
            , test "oneOf matches second parser" <|
                \() ->
                    Expect.equal (Just "blog:99")
                        (parseUrl
                            (Parser.oneOf
                                [ Parser.map (\t -> "topic:" ++ t) (Parser.s "topic" </> Parser.string)
                                , Parser.map (\i -> "blog:" ++ String.fromInt i) (Parser.s "blog" </> Parser.int)
                                ]
                            )
                            "https://example.com/blog/99"
                        )
            , test "oneOf returns Nothing when nothing matches" <|
                \() ->
                    Expect.equal Nothing
                        (parseUrl
                            (Parser.oneOf
                                [ Parser.map (\t -> "topic:" ++ t) (Parser.s "topic" </> Parser.string)
                                , Parser.map (\i -> "blog:" ++ String.fromInt i) (Parser.s "blog" </> Parser.int)
                                ]
                            )
                            "https://example.com/settings"
                        )
            ]
        , describe "fragment"
            [ test "fragment extracts hash value" <|
                \() ->
                    Expect.equal (Just (Just "section1"))
                        (parseUrl
                            (Parser.map (\f -> f) (Parser.s "page" </> Parser.fragment identity))
                            "https://example.com/page#section1"
                        )
            , test "fragment returns Nothing when absent" <|
                \() ->
                    Expect.equal (Just Nothing)
                        (parseUrl
                            (Parser.map (\f -> f) (Parser.s "page" </> Parser.fragment identity))
                            "https://example.com/page"
                        )
            , test "fragment returns Just empty string for bare hash" <|
                \() ->
                    Expect.equal (Just (Just ""))
                        (parseUrl
                            (Parser.map (\f -> f) (Parser.s "page" </> Parser.fragment identity))
                            "https://example.com/page#"
                        )
            ]
        , describe "query integration with <?>  "
            [ test "<?> extracts query parameter" <|
                \() ->
                    Expect.equal (Just (Just "cats"))
                        (parseUrl
                            (Parser.s "search" <?> Query.string "q")
                            "https://example.com/search?q=cats"
                        )
            , test "<?> returns Nothing for missing param" <|
                \() ->
                    Expect.equal (Just Nothing)
                        (parseUrl
                            (Parser.s "search" <?> Query.string "q")
                            "https://example.com/search"
                        )
            , test "<?> returns Nothing for missing param with other params" <|
                \() ->
                    Expect.equal (Just Nothing)
                        (parseUrl
                            (Parser.s "search" <?> Query.string "q")
                            "https://example.com/search?page=1"
                        )
            ]
        , describe "map"
            [ test "map transforms parsed value" <|
                \() ->
                    Expect.equal (Just 84)
                        (parseUrl
                            (Parser.map (\n -> n * 2) (Parser.s "num" </> Parser.int))
                            "https://example.com/num/42"
                        )
            , test "map with multi-segment constructor" <|
                \() ->
                    Expect.equal (Just "bob:42")
                        (parseUrl
                            (Parser.map (\name id -> name ++ ":" ++ String.fromInt id)
                                (Parser.s "user" </> Parser.string </> Parser.s "comment" </> Parser.int)
                            )
                            "https://example.com/user/bob/comment/42"
                        )
            ]
        , describe "custom"
            [ test "custom parser that accepts only .css files" <|
                \() ->
                    Expect.equal (Just "style.css")
                        (parseUrl
                            (Parser.s "assets" </> Parser.custom "CSS_FILE" (\seg ->
                                if String.endsWith ".css" seg then
                                    Just seg
                                else
                                    Nothing
                            ))
                            "https://example.com/assets/style.css"
                        )
            , test "custom parser rejects non-matching segment" <|
                \() ->
                    Expect.equal Nothing
                        (parseUrl
                            (Parser.s "assets" </> Parser.custom "CSS_FILE" (\seg ->
                                if String.endsWith ".css" seg then
                                    Just seg
                                else
                                    Nothing
                            ))
                            "https://example.com/assets/style.js"
                        )
            , test "custom parser with transformation" <|
                \() ->
                    Expect.equal (Just 42)
                        (parseUrl
                            (Parser.s "hex" </> Parser.custom "HEX" (\seg ->
                                if String.startsWith "0x" seg then
                                    String.toInt (String.dropLeft 2 seg)
                                else
                                    Nothing
                            ))
                            "https://example.com/hex/0x42"
                        )
            , test "custom parser fails on empty path" <|
                \() ->
                    Expect.equal Nothing
                        (parseUrl
                            (Parser.custom "ANY" Just)
                            "https://example.com/"
                        )
            ]
        , describe "query function"
            [ test "query used directly with </> extracts param" <|
                \() ->
                    Expect.equal (Just (Just "cats"))
                        (parseUrl
                            (Parser.s "search" </> Parser.query (Query.string "q"))
                            "https://example.com/search?q=cats"
                        )
            , test "query used directly returns Nothing for missing param" <|
                \() ->
                    Expect.equal (Just Nothing)
                        (parseUrl
                            (Parser.s "search" </> Parser.query (Query.string "q"))
                            "https://example.com/search"
                        )
            , test "query with int parser" <|
                \() ->
                    Expect.equal (Just (Just 5))
                        (parseUrl
                            (Parser.s "items" </> Parser.query (Query.int "page"))
                            "https://example.com/items?page=5"
                        )
            , test "query with map2 combines two params" <|
                \() ->
                    Expect.equal (Just (Just "cats-2"))
                        (parseUrl
                            (Parser.s "search" </> Parser.query
                                (Query.map2
                                    (\q p ->
                                        case q of
                                            Just qVal ->
                                                case p of
                                                    Just pVal ->
                                                        Just (qVal ++ "-" ++ String.fromInt pVal)

                                                    Nothing ->
                                                        Nothing

                                            Nothing ->
                                                Nothing
                                    )
                                    (Query.string "q")
                                    (Query.int "page")
                                )
                            )
                            "https://example.com/search?q=cats&page=2"
                        )
            ]
        , describe "edge cases"
            [ test "empty path segments are handled" <|
                \() ->
                    Expect.equal (Just ())
                        (parseUrl (Parser.map () Parser.top) "https://example.com")
            , test "no match returns Nothing" <|
                \() ->
                    Expect.equal Nothing
                        (parseUrl (Parser.s "blog" </> Parser.int) "https://example.com/shop/42")
            , test "extra path segments cause no match" <|
                \() ->
                    Expect.equal Nothing
                        (parseUrl (Parser.map () (Parser.s "blog" </> Parser.top)) "https://example.com/blog/42/extra")
            , test "query params do not interfere with path parsing" <|
                \() ->
                    Expect.equal (Just 7)
                        (parseUrl (Parser.s "blog" </> Parser.int) "https://example.com/blog/7?q=wolf")
            , test "fragment does not interfere with path parsing" <|
                \() ->
                    Expect.equal (Just 7)
                        (parseUrl (Parser.s "blog" </> Parser.int) "https://example.com/blog/7#top")
            ]
        ]



-- PARSER ADDITIONAL TESTS


parserAdditionalTests : Test
parserAdditionalTests =
    describe "Url.Parser additional"
        [ describe "percent-encoded path segments"
            [ test "percent-encoded string segment is kept raw in path" <|
                \() ->
                    Expect.equal (Just "hello%20world")
                        (parseUrl (Parser.s "user" </> Parser.string) "https://example.com/user/hello%20world")
            , test "percent-encoded special characters in path are kept raw" <|
                \() ->
                    Expect.equal (Just "a%26b%3Dc")
                        (parseUrl (Parser.s "item" </> Parser.string) "https://example.com/item/a%26b%3Dc")
            ]
        , describe "parse with query params containing percent-encoded keys"
            [ test "percent-encoded query key is decoded" <|
                \() ->
                    Expect.equal (Just (Just "val"))
                        (parseUrl
                            (Parser.s "search" <?> Query.string "my key")
                            "https://example.com/search?my%20key=val"
                        )
            , test "percent-encoded query value is decoded" <|
                \() ->
                    Expect.equal (Just (Just "hello world"))
                        (parseUrl
                            (Parser.s "search" <?> Query.string "q")
                            "https://example.com/search?q=hello%20world"
                        )
            ]
        , describe "parse with empty and multiple path segments"
            [ test "multiple string segments" <|
                \() ->
                    Expect.equal (Just "alice-42")
                        (parseUrl
                            (Parser.map (\name id -> name ++ "-" ++ String.fromInt id)
                                (Parser.s "user" </> Parser.string </> Parser.s "post" </> Parser.int)
                            )
                            "https://example.com/user/alice/post/42"
                        )
            , test "oneOf with top and nested" <|
                \() ->
                    Expect.equal (Just "home")
                        (parseUrl
                            (Parser.oneOf
                                [ Parser.map "home" Parser.top
                                , Parser.map "about" (Parser.s "about")
                                ]
                            )
                            "https://example.com/"
                        )
            , test "oneOf falls through to second when first fails" <|
                \() ->
                    Expect.equal (Just "about")
                        (parseUrl
                            (Parser.oneOf
                                [ Parser.map "home" (Parser.s "home")
                                , Parser.map "about" (Parser.s "about")
                                ]
                            )
                            "https://example.com/about"
                        )
            ]
        , describe "fragment combined with path and query"
            [ test "path + query + fragment all parsed" <|
                \() ->
                    Expect.equal (Just "42-cats-sec")
                        (parseUrl
                            (Parser.map (\id q f ->
                                String.fromInt id
                                    ++ "-" ++ Maybe.withDefault "none" q
                                    ++ "-" ++ Maybe.withDefault "nofrag" f
                            )
                                (Parser.s "blog" </> Parser.int <?> Query.string "q" </> Parser.fragment identity)
                            )
                            "https://example.com/blog/42?q=cats#sec"
                        )
            , test "fragment with identity on root" <|
                \() ->
                    Expect.equal (Just (Just "top"))
                        (parseUrl
                            (Parser.map identity (Parser.fragment identity))
                            "https://example.com/#top"
                        )
            ]
        , describe "query with malformed params"
            [ test "query param without = sign is ignored but valid params still work" <|
                \() ->
                    Expect.equal (Just (Just "cats"))
                        (parseUrl
                            (Parser.s "search" <?> Query.string "q")
                            "https://example.com/search?badparam&q=cats"
                        )
            , test "query param with invalid percent-encoding in key is skipped" <|
                \() ->
                    Expect.equal (Just Nothing)
                        (parseUrl
                            (Parser.s "search" <?> Query.string "%ZZ")
                            "https://example.com/search?%ZZ=val"
                        )
            ]
        , describe "s with empty unvisited"
            [ test "s fails when path is exhausted" <|
                \() ->
                    Expect.equal Nothing
                        (parseUrl (Parser.map () (Parser.s "blog" </> Parser.s "post")) "https://example.com/blog")
            ]
        , describe "getFirstMatch skips states with remaining unvisited"
            [ test "parser that leaves unconsumed segments returns Nothing" <|
                \() ->
                    Expect.equal Nothing
                        (parseUrl (Parser.map () (Parser.s "a")) "https://example.com/a/b/c")
            ]
        ]



-- URL PARSER QUERY


queryParserTests : Test
queryParserTests =
    describe "Url.Parser.Query"
        [ describe "Query.string"
            [ test "extracts string query param" <|
                \() ->
                    Expect.equal (Just (Just "cats"))
                        (parseUrl
                            (Parser.s "search" <?> Query.string "q")
                            "https://example.com/search?q=cats"
                        )
            , test "returns Nothing for missing key" <|
                \() ->
                    Expect.equal (Just Nothing)
                        (parseUrl
                            (Parser.s "search" <?> Query.string "q")
                            "https://example.com/search?other=val"
                        )
            , test "returns Nothing for duplicate keys" <|
                \() ->
                    Expect.equal (Just Nothing)
                        (parseUrl
                            (Parser.s "search" <?> Query.string "q")
                            "https://example.com/search?q=cats&q=dogs"
                        )
            ]
        , describe "Query.int"
            [ test "extracts int query param" <|
                \() ->
                    Expect.equal (Just (Just 2))
                        (parseUrl
                            (Parser.s "items" <?> Query.int "page")
                            "https://example.com/items?page=2"
                        )
            , test "returns Nothing for non-integer value" <|
                \() ->
                    Expect.equal (Just Nothing)
                        (parseUrl
                            (Parser.s "items" <?> Query.int "page")
                            "https://example.com/items?page=abc"
                        )
            , test "returns Nothing for missing key" <|
                \() ->
                    Expect.equal (Just Nothing)
                        (parseUrl
                            (Parser.s "items" <?> Query.int "page")
                            "https://example.com/items"
                        )
            ]
        , describe "Query.enum"
            [ test "extracts enum query param" <|
                \() ->
                    Expect.equal (Just (Just "asc"))
                        (parseUrl
                            (Parser.s "items" <?> Query.enum "sort" (Dict.fromList [ ("ascending", "asc"), ("descending", "desc") ]))
                            "https://example.com/items?sort=ascending"
                        )
            , test "returns Nothing for value not in dict" <|
                \() ->
                    Expect.equal (Just Nothing)
                        (parseUrl
                            (Parser.s "items" <?> Query.enum "sort" (Dict.fromList [ ("ascending", "asc"), ("descending", "desc") ]))
                            "https://example.com/items?sort=random"
                        )
            , test "returns Nothing for missing key" <|
                \() ->
                    Expect.equal (Just Nothing)
                        (parseUrl
                            (Parser.s "items" <?> Query.enum "sort" (Dict.fromList [ ("ascending", "asc") ]))
                            "https://example.com/items"
                        )
            ]
        , describe "Query.custom"
            [ test "extracts multiple values for same key" <|
                \() ->
                    Expect.equal (Just ["red", "blue"])
                        (parseUrl
                            (Parser.s "items" <?> Query.custom "tag" identity)
                            "https://example.com/items?tag=red&tag=blue"
                        )
            , test "returns empty list for missing key" <|
                \() ->
                    Expect.equal (Just [])
                        (parseUrl
                            (Parser.s "items" <?> Query.custom "tag" identity)
                            "https://example.com/items"
                        )
            , test "returns single-element list for one value" <|
                \() ->
                    Expect.equal (Just ["red"])
                        (parseUrl
                            (Parser.s "items" <?> Query.custom "tag" identity)
                            "https://example.com/items?tag=red"
                        )
            ]
        , describe "Query.map"
            [ test "map transforms query result" <|
                \() ->
                    Expect.equal (Just 1)
                        (parseUrl
                            (Parser.s "items" <?> Query.map (Maybe.withDefault 1) (Query.int "page"))
                            "https://example.com/items"
                        )
            , test "map preserves present value" <|
                \() ->
                    Expect.equal (Just 5)
                        (parseUrl
                            (Parser.s "items" <?> Query.map (Maybe.withDefault 1) (Query.int "page"))
                            "https://example.com/items?page=5"
                        )
            ]
        , describe "Query.map2"
            [ test "map2 combines two query params" <|
                \() ->
                    Expect.equal (Just "cats-2")
                        (parseUrl
                            (Parser.s "search" <?>
                                Query.map2
                                    (\q p -> Maybe.withDefault "" q ++ "-" ++ String.fromInt (Maybe.withDefault 0 p))
                                    (Query.string "q")
                                    (Query.int "page")
                            )
                            "https://example.com/search?q=cats&page=2"
                        )
            , test "map2 with missing params uses defaults" <|
                \() ->
                    Expect.equal (Just "-0")
                        (parseUrl
                            (Parser.s "search" <?>
                                Query.map2
                                    (\q p -> Maybe.withDefault "" q ++ "-" ++ String.fromInt (Maybe.withDefault 0 p))
                                    (Query.string "q")
                                    (Query.int "page")
                            )
                            "https://example.com/search"
                        )
            ]
        , describe "Query.map3"
            [ test "map3 combines three query params" <|
                \() ->
                    Expect.equal (Just "cats-2-asc")
                        (parseUrl
                            (Parser.s "search" <?>
                                Query.map3
                                    (\q p s -> Maybe.withDefault "" q ++ "-" ++ String.fromInt (Maybe.withDefault 0 p) ++ "-" ++ Maybe.withDefault "none" s)
                                    (Query.string "q")
                                    (Query.int "page")
                                    (Query.string "sort")
                            )
                            "https://example.com/search?q=cats&page=2&sort=asc"
                        )
            , test "map3 with partial params" <|
                \() ->
                    Expect.equal (Just "cats-0-none")
                        (parseUrl
                            (Parser.s "search" <?>
                                Query.map3
                                    (\q p s -> Maybe.withDefault "" q ++ "-" ++ String.fromInt (Maybe.withDefault 0 p) ++ "-" ++ Maybe.withDefault "none" s)
                                    (Query.string "q")
                                    (Query.int "page")
                                    (Query.string "sort")
                            )
                            "https://example.com/search?q=cats"
                        )
            ]
        , describe "Query.map4"
            [ test "map4 combines four query params" <|
                \() ->
                    Expect.equal (Just "cats-2-asc-10")
                        (parseUrl
                            (Parser.s "search" <?>
                                Query.map4
                                    (\q p s l ->
                                        Maybe.withDefault "" q
                                            ++ "-" ++ String.fromInt (Maybe.withDefault 0 p)
                                            ++ "-" ++ Maybe.withDefault "none" s
                                            ++ "-" ++ String.fromInt (Maybe.withDefault 0 l)
                                    )
                                    (Query.string "q")
                                    (Query.int "page")
                                    (Query.string "sort")
                                    (Query.int "limit")
                            )
                            "https://example.com/search?q=cats&page=2&sort=asc&limit=10"
                        )
            ]
        , describe "Query.map5"
            [ test "map5 combines five query params" <|
                \() ->
                    Expect.equal (Just "a-1-b-2-c")
                        (parseUrl
                            (Parser.s "x" <?>
                                Query.map5
                                    (\a b c d e ->
                                        Maybe.withDefault "" a
                                            ++ "-" ++ String.fromInt (Maybe.withDefault 0 b)
                                            ++ "-" ++ Maybe.withDefault "" c
                                            ++ "-" ++ String.fromInt (Maybe.withDefault 0 d)
                                            ++ "-" ++ Maybe.withDefault "" e
                                    )
                                    (Query.string "a")
                                    (Query.int "b")
                                    (Query.string "c")
                                    (Query.int "d")
                                    (Query.string "e")
                            )
                            "https://example.com/x?a=a&b=1&c=b&d=2&e=c"
                        )
            ]
        , describe "Query.map6"
            [ test "map6 combines six query params" <|
                \() ->
                    Expect.equal (Just "a-1-b-2-c-3")
                        (parseUrl
                            (Parser.s "x" <?>
                                Query.map6
                                    (\a b c d e f ->
                                        Maybe.withDefault "" a
                                            ++ "-" ++ String.fromInt (Maybe.withDefault 0 b)
                                            ++ "-" ++ Maybe.withDefault "" c
                                            ++ "-" ++ String.fromInt (Maybe.withDefault 0 d)
                                            ++ "-" ++ Maybe.withDefault "" e
                                            ++ "-" ++ String.fromInt (Maybe.withDefault 0 f)
                                    )
                                    (Query.string "a")
                                    (Query.int "b")
                                    (Query.string "c")
                                    (Query.int "d")
                                    (Query.string "e")
                                    (Query.int "f")
                            )
                            "https://example.com/x?a=a&b=1&c=b&d=2&e=c&f=3"
                        )
            ]
        , describe "Query.map7"
            [ test "map7 combines seven query params" <|
                \() ->
                    Expect.equal (Just "a-1-b-2-c-3-d")
                        (parseUrl
                            (Parser.s "x" <?>
                                Query.map7
                                    (\a b c d e f g ->
                                        Maybe.withDefault "" a
                                            ++ "-" ++ String.fromInt (Maybe.withDefault 0 b)
                                            ++ "-" ++ Maybe.withDefault "" c
                                            ++ "-" ++ String.fromInt (Maybe.withDefault 0 d)
                                            ++ "-" ++ Maybe.withDefault "" e
                                            ++ "-" ++ String.fromInt (Maybe.withDefault 0 f)
                                            ++ "-" ++ Maybe.withDefault "" g
                                    )
                                    (Query.string "a")
                                    (Query.int "b")
                                    (Query.string "c")
                                    (Query.int "d")
                                    (Query.string "e")
                                    (Query.int "f")
                                    (Query.string "g")
                            )
                            "https://example.com/x?a=a&b=1&c=b&d=2&e=c&f=3&g=d"
                        )
            ]
        , describe "Query.map8"
            [ test "map8 combines eight query params" <|
                \() ->
                    Expect.equal (Just "a-1-b-2-c-3-d-4")
                        (parseUrl
                            (Parser.s "x" <?>
                                Query.map8
                                    (\a b c d e f g h ->
                                        Maybe.withDefault "" a
                                            ++ "-" ++ String.fromInt (Maybe.withDefault 0 b)
                                            ++ "-" ++ Maybe.withDefault "" c
                                            ++ "-" ++ String.fromInt (Maybe.withDefault 0 d)
                                            ++ "-" ++ Maybe.withDefault "" e
                                            ++ "-" ++ String.fromInt (Maybe.withDefault 0 f)
                                            ++ "-" ++ Maybe.withDefault "" g
                                            ++ "-" ++ String.fromInt (Maybe.withDefault 0 h)
                                    )
                                    (Query.string "a")
                                    (Query.int "b")
                                    (Query.string "c")
                                    (Query.int "d")
                                    (Query.string "e")
                                    (Query.int "f")
                                    (Query.string "g")
                                    (Query.int "h")
                            )
                            "https://example.com/x?a=a&b=1&c=b&d=2&e=c&f=3&g=d&h=4"
                        )
            , test "map8 with all params missing uses defaults" <|
                \() ->
                    Expect.equal (Just "-0--0--0--0")
                        (parseUrl
                            (Parser.s "x" <?>
                                Query.map8
                                    (\a b c d e f g h ->
                                        Maybe.withDefault "" a
                                            ++ "-" ++ String.fromInt (Maybe.withDefault 0 b)
                                            ++ "-" ++ Maybe.withDefault "" c
                                            ++ "-" ++ String.fromInt (Maybe.withDefault 0 d)
                                            ++ "-" ++ Maybe.withDefault "" e
                                            ++ "-" ++ String.fromInt (Maybe.withDefault 0 f)
                                            ++ "-" ++ Maybe.withDefault "" g
                                            ++ "-" ++ String.fromInt (Maybe.withDefault 0 h)
                                    )
                                    (Query.string "a")
                                    (Query.int "b")
                                    (Query.string "c")
                                    (Query.int "d")
                                    (Query.string "e")
                                    (Query.int "f")
                                    (Query.string "g")
                                    (Query.int "h")
                            )
                            "https://example.com/x"
                        )
            ]
        ]



-- QUERY PARSER ADDITIONAL TESTS


queryParserAdditionalTests : Test
queryParserAdditionalTests =
    describe "Url.Parser.Query additional"
        [ describe "Query.string edge cases"
            [ test "string with empty value" <|
                \() ->
                    Expect.equal (Just (Just ""))
                        (parseUrl
                            (Parser.s "x" <?> Query.string "q")
                            "https://example.com/x?q="
                        )
            ]
        , describe "Query.int edge cases"
            [ test "int with duplicate keys returns Nothing" <|
                \() ->
                    Expect.equal (Just Nothing)
                        (parseUrl
                            (Parser.s "x" <?> Query.int "n")
                            "https://example.com/x?n=1&n=2"
                        )
            , test "int with empty string returns Nothing" <|
                \() ->
                    Expect.equal (Just Nothing)
                        (parseUrl
                            (Parser.s "x" <?> Query.int "n")
                            "https://example.com/x?n="
                        )
            , test "int with negative value" <|
                \() ->
                    Expect.equal (Just (Just -5))
                        (parseUrl
                            (Parser.s "x" <?> Query.int "n")
                            "https://example.com/x?n=-5"
                        )
            ]
        , describe "Query.enum edge cases"
            [ test "enum with duplicate keys returns Nothing" <|
                \() ->
                    Expect.equal (Just Nothing)
                        (parseUrl
                            (Parser.s "x" <?> Query.enum "s" (Dict.fromList [ ("a", 1), ("b", 2) ]))
                            "https://example.com/x?s=a&s=b"
                        )
            , test "enum with empty value not in dict returns Nothing" <|
                \() ->
                    Expect.equal (Just Nothing)
                        (parseUrl
                            (Parser.s "x" <?> Query.enum "s" (Dict.fromList [ ("a", 1) ]))
                            "https://example.com/x?s="
                        )
            ]
        , describe "Query.custom edge cases"
            [ test "custom with filterMap on multiple values" <|
                \() ->
                    Expect.equal (Just [2, 7])
                        (parseUrl
                            (Parser.s "x" <?> Query.custom "n" (List.filterMap String.toInt))
                            "https://example.com/x?n=2&n=7"
                        )
            , test "custom with filterMap ignores non-parseable values" <|
                \() ->
                    Expect.equal (Just [2])
                        (parseUrl
                            (Parser.s "x" <?> Query.custom "n" (List.filterMap String.toInt))
                            "https://example.com/x?n=2&n=abc"
                        )
            , test "custom with List.length counts values" <|
                \() ->
                    Expect.equal (Just 3)
                        (parseUrl
                            (Parser.s "x" <?> Query.custom "t" List.length)
                            "https://example.com/x?t=a&t=b&t=c"
                        )
            ]
        , describe "Query.map additional"
            [ test "map with String.toUpper on string param" <|
                \() ->
                    Expect.equal (Just "CATS")
                        (parseUrl
                            (Parser.s "x" <?> Query.map (Maybe.withDefault "NONE" >> String.toUpper) (Query.string "q"))
                            "https://example.com/x?q=cats"
                        )
            ]
        , describe "Query.map2 additional"
            [ test "map2 with one param present one missing" <|
                \() ->
                    Expect.equal (Just "cats-0")
                        (parseUrl
                            (Parser.s "x" <?>
                                Query.map2
                                    (\q p -> Maybe.withDefault "" q ++ "-" ++ String.fromInt (Maybe.withDefault 0 p))
                                    (Query.string "q")
                                    (Query.int "page")
                            )
                            "https://example.com/x?q=cats"
                        )
            ]
        , describe "Query.map4 additional"
            [ test "map4 with all params missing" <|
                \() ->
                    Expect.equal (Just "-0--0")
                        (parseUrl
                            (Parser.s "x" <?>
                                Query.map4
                                    (\a b c d ->
                                        Maybe.withDefault "" a
                                            ++ "-" ++ String.fromInt (Maybe.withDefault 0 b)
                                            ++ "-" ++ Maybe.withDefault "" c
                                            ++ "-" ++ String.fromInt (Maybe.withDefault 0 d)
                                    )
                                    (Query.string "a")
                                    (Query.int "b")
                                    (Query.string "c")
                                    (Query.int "d")
                            )
                            "https://example.com/x"
                        )
            , test "map4 with partial params" <|
                \() ->
                    Expect.equal (Just "hello-0--0")
                        (parseUrl
                            (Parser.s "x" <?>
                                Query.map4
                                    (\a b c d ->
                                        Maybe.withDefault "" a
                                            ++ "-" ++ String.fromInt (Maybe.withDefault 0 b)
                                            ++ "-" ++ Maybe.withDefault "" c
                                            ++ "-" ++ String.fromInt (Maybe.withDefault 0 d)
                                    )
                                    (Query.string "a")
                                    (Query.int "b")
                                    (Query.string "c")
                                    (Query.int "d")
                            )
                            "https://example.com/x?a=hello"
                        )
            ]
        , describe "Query.map5 additional"
            [ test "map5 with all params missing" <|
                \() ->
                    Expect.equal (Just "-0--0-")
                        (parseUrl
                            (Parser.s "x" <?>
                                Query.map5
                                    (\a b c d e ->
                                        Maybe.withDefault "" a
                                            ++ "-" ++ String.fromInt (Maybe.withDefault 0 b)
                                            ++ "-" ++ Maybe.withDefault "" c
                                            ++ "-" ++ String.fromInt (Maybe.withDefault 0 d)
                                            ++ "-" ++ Maybe.withDefault "" e
                                    )
                                    (Query.string "a")
                                    (Query.int "b")
                                    (Query.string "c")
                                    (Query.int "d")
                                    (Query.string "e")
                            )
                            "https://example.com/x"
                        )
            ]
        , describe "Query.map6 additional"
            [ test "map6 with all params missing" <|
                \() ->
                    Expect.equal (Just "-0--0--0")
                        (parseUrl
                            (Parser.s "x" <?>
                                Query.map6
                                    (\a b c d e f ->
                                        Maybe.withDefault "" a
                                            ++ "-" ++ String.fromInt (Maybe.withDefault 0 b)
                                            ++ "-" ++ Maybe.withDefault "" c
                                            ++ "-" ++ String.fromInt (Maybe.withDefault 0 d)
                                            ++ "-" ++ Maybe.withDefault "" e
                                            ++ "-" ++ String.fromInt (Maybe.withDefault 0 f)
                                    )
                                    (Query.string "a")
                                    (Query.int "b")
                                    (Query.string "c")
                                    (Query.int "d")
                                    (Query.string "e")
                                    (Query.int "f")
                            )
                            "https://example.com/x"
                        )
            ]
        , describe "Query.map7 additional"
            [ test "map7 with all params missing" <|
                \() ->
                    Expect.equal (Just "-0--0--0-")
                        (parseUrl
                            (Parser.s "x" <?>
                                Query.map7
                                    (\a b c d e f g ->
                                        Maybe.withDefault "" a
                                            ++ "-" ++ String.fromInt (Maybe.withDefault 0 b)
                                            ++ "-" ++ Maybe.withDefault "" c
                                            ++ "-" ++ String.fromInt (Maybe.withDefault 0 d)
                                            ++ "-" ++ Maybe.withDefault "" e
                                            ++ "-" ++ String.fromInt (Maybe.withDefault 0 f)
                                            ++ "-" ++ Maybe.withDefault "" g
                                    )
                                    (Query.string "a")
                                    (Query.int "b")
                                    (Query.string "c")
                                    (Query.int "d")
                                    (Query.string "e")
                                    (Query.int "f")
                                    (Query.string "g")
                            )
                            "https://example.com/x"
                        )
            ]
        ]



-- URL BUILDER CUSTOM


builderCustomTests : Test
builderCustomTests =
    describe "Url.Builder.custom"
        [ test "absolute with fragment" <|
            \() ->
                Expect.equal "/packages/canopy/core/latest/String#length"
                    (Builder.custom Builder.Absolute
                        [ "packages", "canopy", "core", "latest", "String" ]
                        []
                        (Just "length")
                    )
        , test "relative with query and no fragment" <|
            \() ->
                Expect.equal "there?name=ferret"
                    (Builder.custom Builder.Relative
                        [ "there" ]
                        [ Builder.string "name" "ferret" ]
                        Nothing
                    )
        , test "crossOrigin with query and fragment" <|
            \() ->
                Expect.equal "https://example.com:8042/over/there?name=ferret#nose"
                    (Builder.custom (Builder.CrossOrigin "https://example.com:8042")
                        [ "over", "there" ]
                        [ Builder.string "name" "ferret" ]
                        (Just "nose")
                    )
        , test "absolute with no path, no query, no fragment" <|
            \() ->
                Expect.equal "/"
                    (Builder.custom Builder.Absolute [] [] Nothing)
        , test "absolute with fragment only" <|
            \() ->
                Expect.equal "/#top"
                    (Builder.custom Builder.Absolute [] [] (Just "top"))
        , test "relative empty" <|
            \() ->
                Expect.equal ""
                    (Builder.custom Builder.Relative [] [] Nothing)
        , test "absolute with query and fragment" <|
            \() ->
                Expect.equal "/search?q=test#results"
                    (Builder.custom Builder.Absolute
                        [ "search" ]
                        [ Builder.string "q" "test" ]
                        (Just "results")
                    )
        ]
